package {{.AppName}}

import (
	"context"

	"github.com/cybersaksham/gogo/queue"
)

func RegisterTasks(app *queue.App) error {
	_, err := app.RegisterTask(AppLabel+".example", func(ctx context.Context, args ...any) (any, error) {
		if err := ctx.Err(); err != nil {
			return nil, err
		}
		return "ok", nil
	}, queue.TaskOptions{Queue: "default", MaxRetries: 3})
	return err
}
