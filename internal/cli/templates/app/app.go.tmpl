package {{.AppName}}

import (
	"context"
	"os"
	"path/filepath"

	"github.com/cybersaksham/gogo/app"
)

const AppLabel = "{{.AppLabel}}"

type Config struct {
	app.BaseConfig
}

func NewConfig() Config {
	root, err := os.Getwd()
	if err != nil {
		root = "."
	}
	return Config{BaseConfig: app.BaseConfig{
		AppName:        "{{.AppName}}",
		AppLabel:       AppLabel,
		AppPath:        filepath.Join(root, "apps", "{{.AppLabel}}"),
		AppVerboseName: "{{.AppLabel}}",
	}}
}

func (c Config) Ready(ctx context.Context, registry *app.Registry) error {
	if err := c.BaseConfig.Ready(ctx, registry); err != nil {
		return err
	}
	registry.RegisterModel(app.ModelResource{AppLabel: AppLabel, Name: "Item"})
	registry.RegisterAdmin(app.AdminResource{AppLabel: AppLabel, ModelName: "Item", Handler: "RegisterAdmin"})
	registry.RegisterRoute(app.RouteResource{AppLabel: AppLabel, Name: AppLabel + ":index", Path: "/" + AppLabel + "/", Handler: "RegisterRoutes"})
	registry.RegisterAPIRoute(app.APIRouteResource{AppLabel: AppLabel, Name: AppLabel + "-item-list", Path: "/api/" + AppLabel + "/items/", Handler: "RegisterAPI"})
	registry.RegisterForm(app.FormResource{AppLabel: AppLabel, Name: "ItemForm", Handler: "NewItemForm"})
	registry.RegisterTemplate(app.TemplateResource{AppLabel: AppLabel, Path: "templates/" + AppLabel})
	registry.RegisterStaticRoot(app.StaticResource{AppLabel: AppLabel, Path: "static/" + AppLabel})
	registry.RegisterTask(app.TaskResource{AppLabel: AppLabel, Name: AppLabel + ".example", Handler: "RegisterTasks"})
	registry.RegisterMigration(app.MigrationResource{AppLabel: AppLabel, Name: "0001_initial"})
	return nil
}
