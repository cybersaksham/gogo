# Framework
GOGO_ENV=development
GOGO_SECRET_KEY=
GOGO_DEBUG=
GOGO_INSTALLED_APPS=
GOGO_MIDDLEWARE=
GOGO_ROOT_URLCONF=
GOGO_DEFAULT_AUTO_FIELD=BigAutoField
GOGO_TIME_ZONE=UTC
GOGO_LANGUAGE_CODE=en-us

# Database
DATABASE_URL=

# Server
GOGO_HTTP_ADDR=:8000
GOGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Static and media files
GOGO_STATIC_URL=/static/
GOGO_STATIC_ROOT=
GOGO_MEDIA_URL=/media/
GOGO_MEDIA_ROOT=
GOGO_TEMPLATE_DIRS=

# Queue
GOGO_BROKER_URL=
GOGO_RESULT_BACKEND=

# Cache
GOGO_CACHE_URL=

# Email
GOGO_EMAIL_URL=

# Sessions and CSRF
GOGO_SESSION_COOKIE_NAME=gogo_sessionid
GOGO_CSRF_COOKIE_NAME=gogo_csrftoken
