func TestGeneratedAppMetadata(t *testing.T) {
	metadata := generatedapp.Item{}.ModelMeta()
	if metadata.AppLabel != generatedapp.AppLabel || metadata.ModelName != "Item" || metadata.TableName != generatedapp.AppLabel+"_item" {
		t.Fatalf("metadata = %#v", metadata)
	}
	for _, field := range []string{"id", "name", "slug", "created_at", "updated_at"} {
		if !hasModelField(metadata.Fields, field) {
			t.Fatalf("metadata fields missing %s: %#v", field, metadata.Fields)
		}
	}
	if len(generatedapp.ModelMetadata()) != 1 {
		t.Fatalf("ModelMetadata length = %d, want 1", len(generatedapp.ModelMetadata()))
	}
}

func TestGeneratedAppRegistrations(t *testing.T) {
	registry := app.NewRegistry()
	if err := generatedapp.NewConfig().Ready(context.Background(), registry); err != nil {
		t.Fatalf("Ready() error = %v", err)
	}
	if got := registry.Models(); len(got) != 1 || got[0].Name != "Item" {
		t.Fatalf("Models() = %#v", got)
	}
	if got := registry.Admin(); len(got) != 1 || got[0].Handler != "RegisterAdmin" {
		t.Fatalf("Admin() = %#v", got)
	}
	if got := registry.Routes(); len(got) != 1 || got[0].Path != "/"+generatedapp.AppLabel+"/" {
		t.Fatalf("Routes() = %#v", got)
	}
	if got := registry.APIRoutes(); len(got) != 1 || got[0].Path != "/api/"+generatedapp.AppLabel+"/items/" {
		t.Fatalf("APIRoutes() = %#v", got)
	}
	if got := registry.Forms(); len(got) != 1 || got[0].Name != "ItemForm" {
		t.Fatalf("Forms() = %#v", got)
	}
	if got := registry.Tasks(); len(got) != 1 || got[0].Name != generatedapp.AppLabel+".example" {
		t.Fatalf("Tasks() = %#v", got)
	}
	if got := registry.Migrations(); len(got) != 1 || got[0].Name != "0001_initial" {
		t.Fatalf("Migrations() = %#v", got)
	}
}

func TestGeneratedAppHTTPRoute(t *testing.T) {
	router := gogohttp.NewRouter()
	if err := generatedapp.RegisterRoutes(router); err != nil {
		t.Fatalf("RegisterRoutes() error = %v", err)
	}
	response := httptest.NewRecorder()
	router.ServeHTTP(response, httptest.NewRequest(http.MethodGet, "/"+generatedapp.AppLabel+"/", nil))
	if response.Code != http.StatusOK || strings.TrimSpace(response.Body.String()) != generatedapp.AppLabel+" index" {
		t.Fatalf("route response = %d body=%q", response.Code, response.Body.String())
	}
}

func TestGeneratedAppAdminFormSerializerAndTasks(t *testing.T) {
	adminRegistry := admin.NewRegistry()
	if err := generatedapp.RegisterAdmin(adminRegistry); err != nil {
		t.Fatalf("RegisterAdmin() error = %v", err)
	}
	modelAdmin, ok := adminRegistry.GetAdmin(generatedapp.AppLabel + ".Item")
	if !ok || !containsString(modelAdmin.ListDisplay, "slug") {
		t.Fatalf("registered admin = %#v, ok=%v", modelAdmin, ok)
	}

	form := generatedapp.NewItemForm(map[string]any{"name": "First item", "slug": "first-item"})
	if !form.IsValid() || form.CleanedData["slug"] != "first-item" {
		t.Fatalf("form valid=%v cleaned=%#v errors=%#v", form.IsValid(), form.CleanedData, form.Errors())
	}

	validated, errors, ok := generatedapp.ItemSerializer().Validate(map[string]any{"name": "First item", "slug": "first-item"})
	if !ok || validated["slug"] != "first-item" || len(errors) != 0 {
		t.Fatalf("serializer valid=%v validated=%#v errors=%#v", ok, validated, errors)
	}

	queueApp := queue.NewApp(queue.AppOptions{})
	if err := generatedapp.RegisterTasks(queueApp); err != nil {
		t.Fatalf("RegisterTasks() error = %v", err)
	}
	task, ok := queueApp.Task(generatedapp.AppLabel + ".example")
	if !ok || task.Options.Queue != "default" || task.Options.MaxRetries != 3 {
		t.Fatalf("registered task = %#v, ok=%v", task, ok)
	}
	result, err := task.Func(context.Background())
	if err != nil || result != "ok" {
		t.Fatalf("task result = %#v, %v", result, err)
	}
}

func TestGeneratedAppAPIRoutes(t *testing.T) {
	t.Setenv("GOGO_SECRET_KEY", "generated-app-test-secret")
	t.Setenv("GOGO_HTTP_ADDR", "127.0.0.1:0")
	t.Setenv("DATABASE_URL", "sqlite://"+filepath.ToSlash(filepath.Join(t.TempDir(), "api.sqlite3")))

	router := api.NewRouter(api.WithAPIPrefix("/api"))
	if err := generatedapp.RegisterAPI(router); err != nil {
		t.Fatalf("RegisterAPI() error = %v", err)
	}
	routes := router.Routes()
	for _, name := range []string{
		generatedapp.AppLabel + "-item-list",
		generatedapp.AppLabel + "-item-create",
		generatedapp.AppLabel + "-item-detail",
		generatedapp.AppLabel + "-item-update",
		generatedapp.AppLabel + "-item-partial-update",
		generatedapp.AppLabel + "-item-destroy",
	} {
		if !hasAPIRoute(routes, name) {
			t.Fatalf("API routes missing %s: %#v", name, routes)
		}
	}
}

func hasModelField(fields []models.FieldMeta, name string) bool {
	for _, field := range fields {
		if field.Name == name {
			return true
		}
	}
	return false
}

func containsString(values []string, needle string) bool {
	for _, value := range values {
		if value == needle {
			return true
		}
	}
	return false
}

func hasAPIRoute(routes []api.Route, name string) bool {
	for _, route := range routes {
		if route.Name == name {
			return true
		}
	}
	return false
}
