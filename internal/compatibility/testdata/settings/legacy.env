# Framework
GOGO_ENV=production
GOGO_SECRET_KEY=legacy-secret-key
GOGO_DEBUG=false
GOGO_INSTALLED_APPS=auth,sessions,admin,blog
GOGO_MIDDLEWARE=gogo.http.HostValidationMiddleware,gogo.auth.SessionMiddleware,gogo.auth.AuthenticationMiddleware
GOGO_ROOT_URLCONF=legacy.urls
GOGO_DEFAULT_AUTO_FIELD=BigAutoField
GOGO_TIME_ZONE=UTC
GOGO_LANGUAGE_CODE=en-us

# Database
DATABASE_URL=postgres://gogo:password@db:5432/gogo?sslmode=require

# Server
GOGO_HTTP_ADDR=:8000
GOGO_ALLOWED_HOSTS=legacy.example.com,admin.legacy.example.com

# Static and media files
GOGO_STATIC_URL=/static/
GOGO_STATIC_ROOT=/app/staticfiles
GOGO_MEDIA_URL=/media/
GOGO_MEDIA_ROOT=/app/media
GOGO_TEMPLATE_DIRS=templates,apps/blog/templates

# Queue
GOGO_BROKER_URL=redis://redis:6379/0
GOGO_RESULT_BACKEND=redis://redis:6379/1

# Cache
GOGO_CACHE_URL=redis://redis:6379/2

# Email
GOGO_EMAIL_URL=smtp://mailer:1025

# Sessions and CSRF
GOGO_SESSION_COOKIE_NAME=legacy_sessionid
GOGO_SESSION_COOKIE_SECURE=true
GOGO_CSRF_COOKIE_NAME=legacy_csrftoken
GOGO_CSRF_COOKIE_SECURE=true
GOGO_CSRF_TRUSTED_ORIGINS=https://legacy.example.com,https://admin.legacy.example.com

# Deploy checks
GOGO_HTTPS_ENABLED=true
GOGO_ADMIN_PATH=/admin
GOGO_ADMIN_PATH_REVIEWED=true
GOGO_DEPLOY_MIGRATIONS_APPLIED=true
GOGO_DEPLOY_STATIC_COLLECTED=true
GOGO_PASSWORD_RESET_ENABLED=true
