package {{.ProjectName}}

import (
	"os"
	"path/filepath"

	"github.com/cybersaksham/gogo/admin"
	"github.com/cybersaksham/gogo/auth"
	"github.com/cybersaksham/gogo/conf"
	"github.com/cybersaksham/gogo/sessions"
)

func NewAdminRegistry() *admin.Registry {
	registry := admin.NewRegistry()
	// gogo:startapp-admin
	return registry
}

func NewAdminSite() *admin.Site {
	site := admin.DefaultSite()
	site.ModelRegistry = NewAdminRegistry()
	authConfig := newAdminAuthConfig(site)
	site.LoginView = admin.LoginView(authConfig)
	site.LogoutView = admin.LogoutView(authConfig)
	site.PasswordChangeView = admin.PasswordChangeView(authConfig)
	site.PermissionPolicy = admin.SessionPermissionPolicy{
		UserStore:    authConfig.UserStore,
		SessionStore: authConfig.SessionStore,
		Cookie:       authConfig.Cookie,
	}
	return site
}

func newAdminAuthConfig(site *admin.Site) admin.AuthViewConfig {
	root := projectRoot()
	return admin.AuthViewConfig{
		Site:         site,
		UserStore:    auth.NewFileUserStore(filepath.Join(root, ".gogo", "auth_users.json")),
		SessionStore: sessions.NewFileStore(filepath.Join(root, ".gogo", "sessions"), adminSecretKey()),
		Cookie:       sessions.CookieOptions{Name: "gogo_sessionid", Path: "/", HttpOnly: true},
	}
}

func projectRoot() string {
	dir, err := os.Getwd()
	if err != nil {
		return "."
	}
	for {
		if _, err := os.Stat(filepath.Join(dir, "go.mod")); err == nil {
			return dir
		}
		parent := filepath.Dir(dir)
		if parent == dir {
			return dir
		}
		dir = parent
	}
}

func adminSecretKey() string {
	settings, err := conf.LoadFromEnv()
	if err == nil && settings.SecretKey != "" {
		return settings.SecretKey
	}
	return "development-admin-session-secret"
}
